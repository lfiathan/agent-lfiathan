# ─── GitHub Configuration (Required) ─────────────────
# Personal access token with repo + workflow permissions
GITHUB_TOKEN=ghp_your_github_personal_access_token_here

# Repository owner (your GitHub username or org)
GITHUB_OWNER=lfiathan

# Repository name
GITHUB_REPO=agent-lfiathan

# ─── GitHub Configuration (Optional) ─────────────────
# Default branch for PRs and workflow dispatch
GITHUB_DEFAULT_BRANCH=main

# GitHub Enterprise API URL (leave empty for github.com)
# GITHUB_API_URL=https://api.github.com

# Path to repo root (auto-detected from MCP server location)
# REPO_PATH=/opt/agent-lfiathan
