# ═══════════════════════════════════════════════════════
#  MCP Servers — Environment Variables
#  Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════

# ─── GitHub Pipeline MCP ─────────────────────────────
# Required for github-pipeline MCP server
GITHUB_TOKEN=ghp_your_github_personal_access_token_here
GITHUB_OWNER=lfiathan
GITHUB_REPO=agent-lfiathan
GITHUB_DEFAULT_BRANCH=main

# GitHub Enterprise (optional, leave empty for github.com)
# GITHUB_API_URL=

# Path to the agent-lfiathan repo root (auto-detected if not set)
# REPO_PATH=/opt/agent-lfiathan
