{
  "name": "agent-lfiathan",
  "version": "1.0.0",
  "description": "Financial agent backend powered by Hermes, Fastify, PostgreSQL, and Redis",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "migrate": "knex --knexfile src/config/knexfile.js migrate:latest",
    "migrate:rollback": "knex --knexfile src/config/knexfile.js migrate:rollback",
    "migrate:make": "knex --knexfile src/config/knexfile.js migrate:make",
    "seed": "knex --knexfile src/config/knexfile.js seed:run"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/sensible": "^6.0.3",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.4.2",
    "knex": "^3.1.0",
    "pg": "^8.13.1",
    "pino-pretty": "^13.1.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
