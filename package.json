{
  "name": "agent-lfiathan",
  "version": "1.0.0",
  "description": "Financial agent backend powered by Hermes, Fastify, PostgreSQL, and Redis",
  "type": "module",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/src/server.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx node_modules/.bin/knex --knexfile src/config/knexfile.ts migrate:latest",
    "migrate:rollback": "tsx node_modules/.bin/knex --knexfile src/config/knexfile.ts migrate:rollback",
    "migrate:make": "tsx node_modules/.bin/knex --knexfile src/config/knexfile.ts migrate:make",
    "seed": "tsx node_modules/.bin/knex --knexfile src/config/knexfile.ts seed:run",
    "import:transactions:emails": "tsx src/jobs/transaction-email-import.job.ts",
    "import:transactions:emails:review": "tsx src/jobs/transaction-email-review.job.ts",
    "money:monthly:rollup": "tsx src/jobs/money-monthly-rollup.job.ts",
    "cron:install:transaction-email-import": "bash scripts/install-cron-transaction-email-import.sh",
    "report:weekly:financial-audit": "tsx src/jobs/weekly-financial-audit.job.ts",
    "cron:install:weekly-financial-audit": "bash scripts/install-cron-weekly-financial-audit.sh"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/sensible": "^6.0.3",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.4.2",
    "knex": "^3.1.0",
    "pg": "^8.13.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
