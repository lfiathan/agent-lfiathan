# ═══════════════════════════════════════════════════════
#  Agent Lfiathan — Environment Variables
#  Copy this file to .env and fill in your values.
#  Lines starting with # are comments.
# ═══════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# ─── Database (PostgreSQL) ───────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=lfiathan
DB_PASSWORD=your_database_password_here
DB_NAME=agent_lfiathan
# DB_POOL_MIN=2
# DB_POOL_MAX=10

# ─── Redis ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=lfiathan:
REDIS_DEFAULT_TTL=300

# ─── Hermes Agent ────────────────────────────────────
HERMES_API_URL=http://localhost:8642
HERMES_API_KEY=your_hermes_api_key_here
HERMES_MODEL=minimax/minimax-m2.5:free
HERMES_TIMEOUT=30000

# ─── OpenRouter (used by Hermes for LLM access) ─────
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key_here

# ─── Telegram (optional, for Hermes gateway) ────────
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ─── GitHub (for MCP & CI/CD) ───────────────────────
# Personal access token with repo + workflow permissions
# GITHUB_TOKEN=ghp_your_github_personal_access_token_here
# GITHUB_OWNER=lfiathan
# GITHUB_REPO=agent-lfiathan

# ─── VPS Deployment (used by CI/CD pipeline) ────────
# These are configured as GitHub Repository Secrets,
# not in this .env file. Listed here for reference:
#
# VPS_HOST       — Your VPS IP address or hostname
# VPS_USER       — SSH username (e.g. root)
# VPS_SSH_KEY    — Private SSH key for authentication
# VPS_PORT       — SSH port (default: 22)
# DEPLOY_PATH    — App directory on VPS (default: /opt/agent-lfiathan)
