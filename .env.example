# ─── Application ──────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# ─── Database (PostgreSQL) ───────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=lfiathan
DB_PASSWORD=lfiathan_secret
DB_NAME=agent_lfiathan

# ─── Redis ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=lfiathan:
REDIS_DEFAULT_TTL=300

# ─── Hermes Agent ────────────────────────────────────
HERMES_API_URL=http://localhost:8642
HERMES_API_KEY=
HERMES_MODEL=minimax/minimax-m2.5:free
HERMES_TIMEOUT=30000

# ─── OpenRouter (used by Hermes for LLM access) ─────
OPENROUTER_API_KEY=your-openrouter-api-key-here

# ─── Telegram (optional, for Hermes gateway) ────────
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
