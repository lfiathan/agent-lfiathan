# ═══════════════════════════════════════════════════════
#  Agent Lfiathan — Environment Variables
#  Copy this file to .env and fill in your values.
#  Lines starting with # are comments.
# ═══════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# ─── Database (PostgreSQL) ───────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=lfiathan
DB_PASSWORD=your_database_password_here
DB_NAME=agent_lfiathan
# DB_POOL_MIN=2
# DB_POOL_MAX=10

# ─── Redis ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=lfiathan:
REDIS_DEFAULT_TTL=300

# ─── Transaction Email Import Job ────────────────────
# Optional: map parsed emails to a specific user in DB.
# TX_EMAIL_IMPORT_USER_ID=uuid_here
# TX_EMAIL_IMPORT_USER_EMAIL=you@example.com
# TX_EMAIL_IMPORT_MAX_EMAILS=200
# TX_EMAIL_IMPORT_LOG_DIR=/opt/agent-lfiathan/logs/email-import
# PYTHON_BIN=python3
# GOOGLE_API_SCRIPT=/root/.hermes/skills/productivity/google-workspace/scripts/google_api.py

# ─── Weekly Financial Audit Job ───────────────────────
# FIN_AUDIT_TZ=Asia/Jakarta

# ─── GitHub (for MCP & CI/CD) ───────────────────────
# Personal access token with repo + workflow permissions
# GITHUB_TOKEN=ghp_your_github_personal_access_token_here
# GITHUB_OWNER=lfiathan
# GITHUB_REPO=agent-lfiathan

# ─── VPS Deployment (used by CI/CD pipeline) ────────
# These are configured as GitHub Repository Secrets,
# not in this .env file. Listed here for reference:
#
# VPS_HOST       — Your VPS IP address or hostname
# VPS_USER       — SSH username (e.g. root)
# VPS_SSH_KEY    — Private SSH key for authentication
# VPS_PORT       — SSH port (default: 22)
# DEPLOY_PATH    — App directory on VPS (default: /opt/agent-lfiathan)
